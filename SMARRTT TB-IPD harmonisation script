##################################################################
# 1. Обработка и проверка
df_labs_processed <- redcap_data %>%
  mutate(redcap_event_name = factor(redcap_event_name, levels = events_order)) %>%
  
  # Разворачиваем ЭКГ на 3 потенциальных замера
  pivot_longer(
    cols = c(ecg_dte_w1, ecg_dte_w2, ecg_dte_m1),
    names_to = "ecg_period",
    values_to = "qt_date_vt1"
  ) %>%
  
  mutate(
    # Выбираем дату ЭКГ в зависимости от визита
    qt_date_raw = case_when(
      redcap_event_name == "v0s_arm_1" ~ ecg0_dte,
      redcap_event_name == "vt1_arm_1" ~ qt_date_vt1,
      TRUE ~ ecg_dte_mx_v2
    ),
    qt_date_obj = ymd(qt_date_raw),
    HB_CALC = as.numeric(hb_res) / 10,
    visit_date_final = if_else(redcap_event_name == "v0s_arm_1", visdat, visit_date),
    
    timeline_order = case_when(
      redcap_event_name == "v0s_arm_1" ~ 1,
      redcap_event_name == "vt1_arm_1" & ecg_period == "ecg_dte_w1" ~ 2,
      redcap_event_name == "vt1_arm_1" & ecg_period == "ecg_dte_w2" ~ 3,
      redcap_event_name == "vt1_arm_1" & ecg_period == "ecg_dte_m1" ~ 4,
      redcap_event_name == "vt2_arm_1" ~ 5,
      redcap_event_name == "vt3_arm_1" ~ 6,
      redcap_event_name == "vt4_arm_1" ~ 7,
      redcap_event_name == "vt5_arm_1" ~ 8,
      redcap_event_name == "vt6_arm_1" ~ 9,
      redcap_event_name == "unscheduled_visit1_arm_1" ~ 10,
      redcap_event_name == "vf6_arm_1" ~ 11,
      redcap_event_name == "vf12_arm_1" ~ 12,
      TRUE ~ 99
    )
  ) %>%
  
  # --- КРИТИЧЕСКИЙ ШАГ: УДАЛЕНИЕ ДУБЛИКАТОВ ---
  filter(
    # Для vt1 оставляем строку, только если в ней реально есть дата ЭКГ
    (redcap_event_name == "vt1_arm_1" & !is.na(qt_date_obj)) |
      # Для всех остальных визитов оставляем только ПЕРВУЮ из трех копий, 
      # созданных пивотом (выбираем по техническому имени ecg_dte_w1)
      (redcap_event_name != "vt1_arm_1" & ecg_period == "ecg_dte_w1")
  ) %>%
  
  # Оставляем строку, если в ней есть хоть какой-то результат (анализ или ЭКГ)
  filter(!is.na(qt_date_obj) | !is.na(hb_res) | !is.na(alt_sgpt_res)) %>%
  
  arrange(record_id, timeline_order) %>%
  group_by(record_id) %>%
  mutate(
    prev_qt_date = lag(qt_date_obj),
    is_qt_error = !is.na(qt_date_obj) & !is.na(prev_qt_date) & qt_date_obj < prev_qt_date
  ) %>%
  ungroup()

# --- ВЫВОД ОШИБОК ---
errors <- df_labs_processed %>% filter(is_qt_error == TRUE)

if(nrow(errors) > 0) {
  message("!!! НАЙДЕНЫ ОШИБКИ ХРОНОЛОГИИ ЭКГ (", nrow(errors), " шт.):")
  print(errors %>% select(record_id, redcap_event_name, qt_date_obj, prev_qt_date), n = Inf)
} else {
  # Добавляем это сообщение, чтобы консоль не молчала
  message("Проверка ЭКГ пройдена успешно: нарушений хронологии не найдено.")
}

# 2. ФОРМИРОВАНИЕ ТАБЛИЦЫ ДЛЯ EXCEL (с очисткой дублей внутри vt1)
df_final_labs <- df_labs_processed %>%
  # Сначала собираем QT_RESULT (как и раньше)
  mutate(
    QT_VAL = case_when(
      redcap_event_name == "v0s_arm_1" ~ coalesce(qtint0_frid, qtint0_frid_2),
      redcap_event_name == "vt1_arm_1" & ecg_period == "ecg_dte_w1" ~ coalesce(qtint_frid_w1, qtint_frid2_w1),
      redcap_event_name == "vt1_arm_1" & ecg_period == "ecg_dte_w2" ~ coalesce(qtint_frid_w2, qtint_frid2_w2),
      redcap_event_name == "vt1_arm_1" & ecg_period == "ecg_dte_m1" ~ coalesce(qtint_frid_m1, qtint_frid2_m1),
      TRUE ~ coalesce(qtint_frid2_mx_v2, qtint_frid_mx_v2)
    )
  ) %>%
  # Группируем по пациенту и визиту, чтобы найти ПЕРВУЮ строку в каждом визите
  group_by(record_id, redcap_event_name) %>%
  mutate(
    # Если это НЕ первая строка в данном визите, зануляем анализы
    is_extra_row = row_number() > 1,
    
    HB_FINAL   = if_else(is_extra_row, NA_real_, HB_CALC),
    ALT_FINAL  = if_else(is_extra_row, NA_real_, as.numeric(alt_sgpt_res)),
    AST_FINAL  = if_else(is_extra_row, NA_real_, as.numeric(ast_sgot_res)),
    BILI_FINAL = if_else(is_extra_row, NA_real_, as.numeric(bilib)),
    PLT_FINAL  = if_else(is_extra_row, NA_real_, as.numeric(plat_res))
  ) %>%
  ungroup() %>%
  transmute(
