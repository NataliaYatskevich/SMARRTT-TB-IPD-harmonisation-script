# NOTE: Dataset-specific transformations
# The following steps are specific to the Belarus RedCap database:
# - handling of baseline sputum culture negative cases
# - pregnancy and infant indicators
# - handling of certain variables on the BASELINE tab
# - linezolid dose reductions
# - adverse event structure
# These steps may need adaptation for other datasets.

# The script also includes several basic data consistency checks 
# (e.g. date logic) to help identify potential data issues before harmonisation.

# Установка и загрузка нужных пакетов
if (!require("openxlsx")) install.packages("openxlsx")
if (!require("readxl")) install.packages("readxl")
library(openxlsx)
library(readxl)
library(dplyr)
library(lubridate)

# Путь к CSV файлу
path_redcap_csv <- "~/RedCap/SixMonthAllOralRegim_DATA_2026-03-13_1531.csv"

# Загрузка
redcap_data <- read.csv("~/RedCap/SixMonthAllOralRegim_DATA_2026-03-13_1531.csv", 
                        check.names = FALSE, 
                        na.strings = c("", "NA", " "), 
                        encoding = "UTF-8")

# Функция-помощник для перекодировки (чтобы не писать одно и то же много раз)
# Для вариантов 1, 2, 9 -> Yes, No, Unknown
recode_129 <- function(x) {
  case_match(as.character(x),
             "1" ~ "Yes",
             "2" ~ "No",
             "9" ~ "Unknown",
             .default = "" # Все остальное (пусто или другие цифры)
  )
}

# Для вариантов 1, 0, 9 -> Yes, No, Unknown
recode_109 <- function(x) {
  case_match(as.character(x),
             "1" ~ "Yes",
             "0" ~ "No",
             "9" ~ "Unknown",
             .default = ""
  )
}

# Обработка
df_baseline_to_write <- redcap_data %>%
  filter(!is.na(subjectid)) %>%
  group_by(subjectid) %>%
  slice(1) %>%
  ungroup() %>%
  mutate(
    # Работаем с датами
    date_hiv_obj = ymd(hiv_dc_dte),
    date_art_obj = ymd(arv_initdat),
    
    # Форматируем дату как DD/MM/YYYY
    # !Важно: format() превращает дату в текст
    art_date_formatted = format(date_art_obj, "%d/%m/%Y")
  ) %>%
  transmute(
    PATIENT_ID        = subjectid,
    SMOKINGSTATUS     = "",
    SMOKINGPACKPERDAY = "",
    SMOKINGTOTALPACKYEAR = "",
    
    # Применяем перекодировку
    ALCOHOL           = recode_129(alcohol),
    ALCOHOLABUSE      = recode_129(alcohol),
    DM                = recode_129(conf_diabmel),
    
    # Логика: если DM == "Yes", то "Unknown", иначе оставляем как есть (или пустой)
    INSULINDEPENDENT  = if_else(DM == "Yes", "Unknown", ""), 
    
    HBA1C             = hba1c,
    RENALFAILURE      = "TBD",
    HEPB              = recode_129(conf_hepatb),
    HEPC              = recode_109(conf_hepatc), # Здесь 1, 0, 9
    OTHERLIVER        = "No",
    
    HIV               = recode_109(hiv_status),   # Здесь 1, 0, 9
    HIV_DIAGNOSISYEAR = year(date_hiv_obj),
    
    NADIR_CD4         = cd4_count,
    CD4               = cd4_count,
    VIRALLOAD         = rna_vl,
    
    ART               = recode_129(arv_ongoing),
    ART_STARTYEAR     = year(date_art_obj),
    ART_STARTDATE     = art_date_formatted,       # Наш новый формат DD/MM/YYYY
    ART_REGIMEN       = if_else(ART == "Yes", "TBD", ""),
    
    # Пустые колонки
    BLMUARMCIR = "", BLEDEMA = "", BLW2PRCNTL = "", 
    BLMALYN = "", BLMALM = "", BLLOWNUTRI = ""
  )

# Запись
wb <- loadWorkbook("~/RedCap/TB_IPD data dictionary v1.0_NY.xlsx")
writeData(wb, sheet = "BASELINE", x = df_baseline_to_write)
saveWorkbook(wb, "~/RedCap/TB_IPD_Updated_Final.xlsx", overwrite = TRUE)

print("Вкладка BASELINE успешно обновлена с новыми форматами, но пока без RENALFAILURE, INSULINDEPENDENT и ART_REGIMEN!")

################################################################
# 1. Сбор данных по всем визитам (склеиваем все записи по препаратам и болезням)
baseline_combined <- redcap_data %>%
  group_by(record_id) %>%
  summarise(
    SUBJ_ID      = first(na.omit(subjectid)),
    HIV_DATE     = first(na.omit(hiv_dc_dte)),
    ART_ONGOING  = first(na.omit(arv_ongoing)),
    ART_DATE     = first(na.omit(arv_initdat)),
    ALCOHOL_VAL  = first(na.omit(alcohol)),
    DM_VAL       = first(na.omit(conf_diabmel)),
    HEPB_VAL     = first(na.omit(conf_hepatb)),
    HEPC_VAL     = first(na.omit(conf_hepatc)),
    HIV_STAT     = first(na.omit(hiv_status)),
    CD4_VAL      = first(na.omit(cd4_count)),
    RNA_VAL      = first(na.omit(rna_vl)),
    HBA1C_VAL    = first(na.omit(hba1c)),
    
    # Собираем ВСЕ записи из cm_drug (препараты) и othmh (болезни) по всем визитам
    ALL_MEDS     = paste(na.omit(as.character(cm_drug)), collapse = " "),
    ALL_MH       = paste(na.omit(as.character(othmh)), collapse = " "),
    .groups = "drop"
  )

# 2. Финальная обработка
df_baseline_final <- baseline_combined %>%
  filter(!is.na(SUBJ_ID)) %>%
  mutate(
    # Поиск схем ART в колонке ALL_MEDS
    ART_FINAL = case_when(
      grepl("DTG", ALL_MEDS) & grepl("TDF", ALL_MEDS) & grepl("FTC", ALL_MEDS) ~ "DTG, TDF, FTC",
      grepl("DTG", ALL_MEDS) & grepl("3TC", ALL_MEDS) & grepl("TDF", ALL_MEDS) ~ "DTG, 3TC, TDF",
      grepl("DTG", ALL_MEDS) & grepl("3TC", ALL_MEDS) & grepl("ABC", ALL_MEDS) ~ "DTG, 3TC, ABC",
      grepl("DTG", ALL_MEDS) & grepl("ZDV", ALL_MEDS) & grepl("3TC", ALL_MEDS) ~ "DTG, ZDV, 3TC",
      TRUE ~ ""
    ),
    
    # Поиск инсулинов
    IS_INSULIN = grepl("инсулин|insulin|актропид|протафан|actrapid|protamin|monoinsulin", ALL_MEDS, ignore.case = TRUE),
    
    # Поиск ХБП
    IS_RENAL = grepl("CKD|ХБП|ХПН|renal failure", ALL_MH, ignore.case = TRUE)
  ) %>%
  transmute(
    PATIENT_ID        = SUBJ_ID,
    SMOKINGSTATUS     = "",
    SMOKINGPACKPERDAY = "",
    SMOKINGTOTALPACKYEAR = "",
    ALCOHOL           = recode_129(ALCOHOL_VAL),
    ALCOHOLABUSE      = ALCOHOL,
    DM                = recode_129(DM_VAL),
    
    # Инсулинозависимость (Yes, если есть диабет и нашли инсулин в любом визите)
    INSULINDEPENDENT  = case_when(
      DM == "Yes" & IS_INSULIN ~ "Yes",
      DM == "Yes" & !IS_INSULIN ~ "No",
      TRUE ~ ""
    ),
    
    HBA1C             = HBA1C_VAL,
    RENALFAILURE      = if_else(IS_RENAL, "Yes", "No"),
    HEPB              = recode_129(HEPB_VAL),
    HEPC              = recode_109(HEPC_VAL),
    OTHERLIVER        = "No",
    HIV               = recode_109(HIV_STAT),
    HIV_DIAGNOSISYEAR = year(ymd(HIV_DATE)),
    NADIR_CD4         = CD4_VAL,
    CD4               = CD4_VAL,
    VIRALLOAD         = RNA_VAL,
    ART               = recode_129(ART_ONGOING),
    ART_STARTYEAR     = year(ymd(ART_DATE)),
    ART_STARTDATE     = format(ymd(ART_DATE), "%d/%m/%Y"),
    ART_REGIMEN       = ART_FINAL,
    
    BLMUARMCIR = "", BLEDEMA = "", BLW2PRCNTL = "", 
    BLMALYN = "", BLMALM = "", BLLOWNUTRI = ""
  )

# 3. Запись
writeData(wb, sheet = "BASELINE", x = df_baseline_final)
saveWorkbook(wb, "~/RedCap/TB_IPD_Updated_Final.xlsx", overwrite = TRUE)

print("Вкладка BASELINE готова! Все данные по сопутствующим заболеваниям собраны.")
