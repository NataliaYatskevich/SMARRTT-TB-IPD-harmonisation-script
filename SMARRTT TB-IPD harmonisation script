##################################################################
# 1. Задаем СТРОГИЙ порядок визитов
events_order <- c(
  "v0s_arm_1", 
  "vt1_arm_1", "vt2_arm_1", "vt3_arm_1", "vt4_arm_1", "vt5_arm_1", "vt6_arm_1", 
  "unscheduled_visit1_arm_1", 
  "vf6_arm_1", "vf12_arm_1"
)

# 2. Обработка WT_HT
df_wtht_to_write <- redcap_data %>%
  # Оставляем только нужные визиты
  filter(redcap_event_name %in% events_order) %>%
  # Убираем пустые записи по весу
  filter(!is.na(weight_vsorres) & weight_vsorres != "") %>%
  
  mutate(
    # Превращаем визит в ФАКТОР с нашим порядком уровней
    redcap_event_name = factor(redcap_event_name, levels = events_order),
    
    # Логика дат (как раньше)
    final_visit_date = if_else(redcap_event_name == "v0s_arm_1", visdat, visit_date),
    date_obj = ymd(final_visit_date)
  ) %>%
  
  # СОРТИРОВКА: сначала по пациенту, потом по заданному ПОРЯДКУ ВИЗИТОВ
  arrange(record_id, redcap_event_name) %>% 
  
  group_by(record_id) %>%
  mutate(
    prev_date = lag(date_obj),
    is_wrong_chronology = date_obj < prev_date
  ) %>%
  ungroup()

# --- ПРОВЕРКА ОШИБОК В КОНСОЛИ ---
errors <- df_wtht_to_write %>% filter(is_wrong_chronology == TRUE)
if(nrow(errors) > 0) {
  message("!!! ВНИМАНИЕ: Нарушена хронология при сортировке по визитам!")
  print(errors %>% select(record_id, redcap_event_name, date_obj, prev_date))
} else {
  message("Все визиты идут в правильном календарном порядке.")
}

