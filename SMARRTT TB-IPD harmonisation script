################################################################## ++++++++++++!!!! 1- ДЛЯ ПРОВЕРКИ СНЯ и НЯИ (те, которые были в когорте в Беларуси!). AE_1 - это дополнительная вкладка
# 1. Максимально расширенный классификатор MedDRA
classify_system <- function(diag_val, other_text) {
  # Подготавливаем текст для поиска (только если диагноз = 99)
  full_text <- tolower(as.character(other_text))
  diag_code <- as.character(diag_val)
  
  case_when(
    # --- СНАЧАЛА ПРОВЕРЯЕМ ЦИФРОВЫЕ КОДЫ ---
    diag_code %in% c("1", "2")   ~ "Cardiac disorders", # Ритм и QT
    diag_code == "10"            ~ "Hepatobiliary disorders", # ALT/AST
    diag_code == "11"            ~ "Nervous system disorders", # Оптический неврит
    diag_code == "16"            ~ "Investigations", # Панкреатит
    diag_code %in% c("18", "19") ~ "Blood and lymphatic system disorders", # Анемия/Нейтрофилы
    diag_code == "21"            ~ "Immune system disorders", # Аллергия
    diag_code == "33"            ~ "Psychiatric disorders", # Психоз
    diag_code == "35"            ~ "Renal and urinary disorders", # Почки
    
    # --- ЗАТЕМ ИЩЕМ ПО ТЕКСТУ (если код 99 или другой) ---
    grepl("перелом|fracture|укус|змеи|шейки|лодыжки|injury", full_text) ~ "Injury, poisoning and procedural complications",
    grepl("clostrid|difficile|инфекц|сепсис|sepsis|токсоплаз|пневмон|infection|абсцед|эмпием|лейкоэнцеф", full_text) ~ "Infections and infestations",
    grepl("рак|карцином|cancer|carcinoma|мтс|neoplasm|опухоль|tongue|язык|пищевод|бронх", full_text) ~ "Neoplasms benign, malignant and unspecified (incl cysts and polyps)",
    grepl("анем|anemia|neutrophil|нейтроф", full_text) ~ "Blood and lymphatic system disorders",
    grepl("билируб|билир|гепат|hepat|алт|аст|transam|bilirubin|alt|ast", full_text) ~ "Hepatobiliary disorders",
    grepl("кишеч|желуд|кровотеч|язва|constipation|ischaemia|intest|рвот|тошн|nausea|gast|непроход|ободоч", full_text) ~ "Gastrointestinal disorders",
    grepl("инсульт|инфаркт|атака|тиа|гемипарез|церебральн|мозг|сужение|neuritis|зрен|глаз|vision", full_text) ~ "Nervous system disorders",
    grepl("сердеч|cardiac|ритм|rhythm|левожелудоч|heart", full_text) ~ "Cardiac disorders",
    grepl("дыхат|хобл|дыхан|copd|легк|остановка", full_text) ~ "Respiratory, thoracic and mediastinal disorders",
    grepl("qt|интервал|амилаз|amylase|pancreatitis|interval|повышение|увеличение", full_text) ~ "Investigations",
    grepl("аллерг|allergic|anaphylax", full_text) ~ "Immune system disorders",
    TRUE ~ "Other"
  )
}

