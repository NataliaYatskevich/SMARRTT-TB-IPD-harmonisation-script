# --- ШАГ 1: Логика конверсии (CULTURE_LOGIC) ---
culture_logic <- df_final_micro %>%
  mutate(date_obj = dmy(CULTURE_DATE)) %>%
  group_by(PATIENT_ID) %>%
  # 1. Запоминаем, был ли позитив на старте (0-1 месяц)
  mutate(is_positive_base = any(CULTURE_RESULT == "Positive" & CULTURE_MONTH <= 1)) %>%
  
  # 2. ИГНОРИРУЕМ контаминацию и пустые записи для поиска цепочки
  filter(CULTURE_RESULT %in% c("Positive", "Negative")) %>%
  arrange(PATIENT_ID, date_obj) %>%
  
  mutate(
    # Текущий визит - отрицательный и это Month 1 или позже
    is_neg_now = (CULTURE_RESULT == "Negative" & CULTURE_MONTH >= 1),
    # Следующий доступный визит (после любого пропуска) - тоже отрицательный
    is_neg_next = lead(CULTURE_RESULT == "Negative"),
    
    # Считаем разницу в днях между текущим и следующим анализом
    days_to_next = as.numeric(difftime(lead(date_obj), date_obj, units = "days")),
    
    # КАНДИДАТ НА КОНВЕРСИЮ: 
    # Два минуса подряд И между ними не менее 7 дней
    conv_candidate = is_neg_now & is_neg_next & (days_to_next >= 7)
  ) %>%
  summarise(
    has_pos_base = first(is_positive_base),
    # Дата конверсии — дата ПЕРВОГО из этой пары «минусов»
    CONV_DATE_OBJ = first(date_obj[conv_candidate == TRUE], na_rm = TRUE),
    HAS_CONVERSION = !is.na(CONV_DATE_OBJ),
    .groups = "drop"
  )

