# 1. Собираем события по препаратам (из TREATMENT_DETAIL)
library(purrr) # Убедись, что библиотека подключена
# 1. Собираем ВСЕ медицинские данные НЯ (СНЯ и Grade 3+ и НЯИ (неврит зрительного нерва/сужение полей зрения))
# последний код второй вариант - правильные степени и названия, но не все
ae_medical_base <- redcap_data %>%
  mutate(
    g_num = as.numeric(as.character(ae_intens)),
    d_txt = as.character(diag_ae),
    o_txt = as.character(oth_ae),
    s_yn  = as.numeric(as.character(sae_yn))
  ) %>%
  # Фильтруем только то, что должно быть в отчете
  filter(s_yn == 1 | g_num >= 3 | (grepl("сужен|полей|зрен", o_txt, ignore.case = TRUE) & g_num == 1)) %>%
  group_by(record_id, redcap_event_name) %>%
  summarise(
    FINAL_DIAG  = first(na.omit(d_txt)),
    FINAL_OTH   = first(na.omit(o_txt)),
    FINAL_GRADE = first(na.omit(g_num)),
    .groups = "drop"
  )
# 1. Собираем события только по факту ОСТАНОВКИ (spec_ch_drug1 == 2)
drug_actions_ae <- df_treatment_events %>%
  filter(chge_reason == 1) %>% 
  group_by(record_id, chged_drug) %>%
  mutate(
    date_obj = ymd(ttt_start_dte)
  ) %>%
  # Работаем с каждой строкой отдельно
  rowwise() %>%
  mutate(
    # Ищем: был ли хоть один старт (1) ПОСЛЕ текущей даты отмены (2) для этого же ID и препарата
    has_future_resume = any(
      df_treatment_events$record_id == record_id & 
        df_treatment_events$chged_drug == chged_drug & 
        df_treatment_events$spec_ch_drug1 == 1 & 
        ymd(df_treatment_events$ttt_start_dte) > date_obj
    )
  ) %>%
  ungroup() %>%
  # Теперь оставляем только строки ОТМЕНЫ (2)
  filter(spec_ch_drug1 == 2) %>%
  mutate(
    is_perm_stop = !has_future_resume,
    is_temp_pause = has_future_resume
  )

# 2. Сборка итоговой таблицы AE
df_ae_final_v_fixed <- drug_actions_ae %>%
  left_join(ae_medical_base, by = c("record_id", "redcap_event_name")) %>%
  mutate(
    SYSTEM_VAL = classify_system(FINAL_DIAG, FINAL_OTH),
    
    # Логика TB_IPD data dictionary v1.0
    STOP_YN   = if_else(is_perm_stop, "Yes", "No"),
    STOP_DATE = if_else(is_perm_stop, format(date_obj, "%d/%m/%Y"), ""),
    
    PAUSE_YN   = if_else(is_temp_pause, "Yes", "No"),
    # Число дней паузы (из расчета в TREATMENT_DETAIL)
    PAUSE_DAYS = if_else(is_temp_pause, as.numeric(pause_calc), NA_real_)
  ) %>%
  transmute(
    PATIENT_ID      = record_id,
    DRUG            = drug_name,
    DRUG_STOP       = STOP_YN,
    DRUG_STOP_DATE  = STOP_DATE,
    DRUG_PAUSE      = PAUSE_YN,
    DRUG_PAUSE_DAYS = PAUSE_DAYS, 
    AE_REASON       = STOP_YN,    # Причина перманентной остановки
    AE_GRADE        = as.numeric(as.character(FINAL_GRADE)),
    AE_SYSTEMORGAN  = SYSTEM_VAL
  ) %>%
  distinct()

