# 1. Функция для "чистой" склейки строк без лишних запятых
clean_paste <- function(...) {
  # Собираем аргументы, убираем NA и пустые строки, склеиваем через запятую
  x <- c(...)
  x <- x[!is.na(x) & x != "" & x != "NA"]
  if(length(x) == 0) return("")
  paste(unique(x), collapse = ", ")
}

