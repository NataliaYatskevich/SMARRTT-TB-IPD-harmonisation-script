      ((diag_txt == "10" | grepl("гепат|ALT|аст", diag_txt, ignore.case = TRUE)) & grade_num >= 3) |
      (grepl("Сужение полей зрения", oth_txt, ignore.case = TRUE) & grade_num == 1)
